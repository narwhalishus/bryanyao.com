---
import Medallion from './desk/Medallion.astro';
import Keyfob from './desk/Keyfob.astro';
import FilmCanister from './desk/FilmCanister.astro';
import CallingCard from './desk/CallingCard.astro';
import WaxSeal from './desk/WaxSeal.astro';
import Stamp from './desk/Stamp.astro';
import RecipeNotebook from './desk/RecipeNotebook.astro';
import WorkingOnNote from './desk/WorkingOnNote.astro';
import Watch from './desk/Watch.astro';
import VinylRecord from './desk/VinylRecord.astro';
import Cufflinks from './desk/Cufflinks.astro';
---

<section class="desk" data-desk aria-label="Bryan's desk">
  <!--
    Every object is positioned via CSS custom props (--x, --y) in % of the desk.
    On desktop, physics overwrites transform at runtime. On mobile, these are the
    final positions. Order here is the z-order from back to front.
  -->

  <div class="obj" style="--x: 28%; --y: 58%;"><WorkingOnNote /></div>
  <div class="obj" style="--x: 86%; --y: 22%;"><RecipeNotebook /></div>

  <div class="obj" style="--x: 50%; --y: 62%;"><CallingCard /></div>

  <div class="obj" style="--x: 14%; --y: 22%;"><VinylRecord /></div>
  <div class="obj" style="--x: 82%; --y: 60%;"><Watch /></div>

  <div class="obj" style="--x: 50%; --y: 18%;"><Medallion /></div>

  <div class="obj" style="--x: 72%; --y: 42%;"><Keyfob /></div>
  <div class="obj" style="--x: 82%; --y: 83%;"><FilmCanister /></div>

  <div class="obj" style="--x: 42%; --y: 48%;"><WaxSeal /></div>
  <div class="obj" style="--x: 30%; --y: 42%;"><Stamp /></div>

  <div class="obj" style="--x: 18%; --y: 82%;"><Cufflinks /></div>
</section>

<style>
  .desk {
    position: relative;
    width: 100%;
    min-height: calc(100vh - 48px);
    overflow: hidden;
  }

  /* Static layout: centered on each object's --x/--y anchor. */
  .obj {
    position: absolute;
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -50%);
    z-index: var(--z-desk);
    will-change: transform;
    user-select: none;
    -webkit-user-drag: none;
    touch-action: none;
  }
  .obj * {
    -webkit-user-drag: none;
  }

  /* Mobile: switch to flow layout so nothing stacks or overflows. */
  @media (max-width: 768px) {
    .desk {
      min-height: 0;
      overflow: visible;
      padding: 1.5rem 1rem 4rem;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem 1rem;
      justify-items: center;
      align-items: center;
    }
    .obj {
      position: static;
      transform: none;
    }
    /* Medallion and card span both cols for emphasis. */
    .obj:has([data-obj='medallion']),
    .obj:has([data-obj='calling-card']) {
      grid-column: 1 / -1;
    }
  }
</style>
