---
// Crimson wax seal. Links to /about.
---

<button class='seal' data-obj='wax-seal' data-drawer='wax-seal' aria-label='Open about preview'>
  <svg viewBox='0 0 100 100' aria-hidden='true'>
    <defs>
      <radialGradient id='wax-fill' cx='40%' cy='35%' r='70%'>
        <stop offset='0%' stop-color='#d84a3a' />
        <stop offset='55%' stop-color='#c13a2a' />
        <stop offset='100%' stop-color='#6a0f0f' />
      </radialGradient>
    </defs>
    <circle cx='50' cy='50' r='44' fill='url(#wax-fill)' />
    <g stroke='#6a0f0f' fill='none' stroke-width='0.6' opacity='0.7'>
      <circle cx='50' cy='50' r='38' stroke-dasharray='1 3' />
    </g>
    <text x='50' y='58' text-anchor='middle' font-family='GFS Didot, Georgia, serif' font-size='26' fill='#3b0606' opacity='0.85'>B</text>
  </svg>
</button>

<style>
  .seal {
    display: inline-block;
    width: 74px;
    height: 74px;
    border-radius: 50%;
    filter: drop-shadow(0 6px 10px rgba(0, 0, 0, 0.45));
    transition: transform var(--dur-short) var(--ease-out-soft);
  }
  .seal:hover,
  .seal:focus-visible {
    transform: scale(1.04);
  }
  .seal svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .seal {
      transition: none;
    }
    .seal:hover,
    .seal:focus-visible {
      transform: none;
    }
  }
</style>
