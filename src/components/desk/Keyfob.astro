---
// Leather keyfob — links to yaodrives.com (external).
---

<a
  class="keyfob"
  data-obj="keyfob"
  href="https://yaodrives.com"
  target="_blank"
  rel="noopener"
  aria-label="Drives — yaodrives.com (opens in new tab)"
>
  <span class="ring" aria-hidden="true"></span>
  <span class="body" aria-hidden="true">
    <span class="stitch"></span>
    <span class="mono">Y</span>
  </span>
  <span class="sr-only">Drives — yaodrives.com</span>
</a>

<style>
  .keyfob {
    position: relative;
    display: inline-flex;
    align-items: center;
    width: 120px;
    height: 54px;
    filter: drop-shadow(0 8px 14px rgba(0, 0, 0, 0.5));
    transition: transform var(--dur-short) var(--ease-out-soft);
  }
  .keyfob:hover,
  .keyfob:focus-visible {
    transform: translateY(-1px) rotate(-1deg);
  }

  .ring {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, #f0f0f2, #8a8a8e 70%, #5c5c60);
    box-shadow:
      inset 0 -2px 3px rgba(0, 0, 0, 0.35),
      inset 0 1px 1px rgba(255, 255, 255, 0.4);
    flex: 0 0 auto;
    position: relative;
    z-index: 2;
    margin-left: 4px;
  }
  .ring::after {
    content: '';
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    background: #15241c;
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.6);
  }

  .body {
    position: relative;
    width: 90px;
    height: 48px;
    margin-left: -10px;
    border-radius: 10px 14px 14px 10px;
    background:
      radial-gradient(ellipse at 20% 30%, #9a7349 0%, #7a5330 45%, #5a3a1e 100%);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 240, 220, 0.12),
      inset 0 -6px 10px rgba(0, 0, 0, 0.35);
  }

  .stitch {
    position: absolute;
    inset: 5px 7px;
    border-radius: 7px 11px 11px 7px;
    border: 1px dashed rgba(255, 240, 220, 0.35);
    opacity: 0.7;
  }

  .mono {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 22px;
    color: rgba(255, 245, 220, 0.55);
    letter-spacing: 0.04em;
    text-shadow: 0 -1px 0 rgba(0, 0, 0, 0.5);
  }

  @media (prefers-reduced-motion: reduce) {
    .keyfob {
      transition: none;
    }
    .keyfob:hover,
    .keyfob:focus-visible {
      transform: none;
    }
  }
</style>
