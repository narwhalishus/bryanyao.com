---
// Identity medallion. Not interactive — it's the "signature" of the desk.
---

<figure class="medallion" data-obj="medallion" aria-label="Bryan Yao · Bay Area · MMXXVI">
  <svg viewBox="0 0 200 200" aria-hidden="true">
    <defs>
      <radialGradient id="med-face" cx="50%" cy="42%" r="60%">
        <stop offset="0%" stop-color="#fff9ea" />
        <stop offset="60%" stop-color="#ece1c8" />
        <stop offset="100%" stop-color="#c9b98f" />
      </radialGradient>
    </defs>

    <circle cx="100" cy="100" r="96" fill="url(#med-face)" />
    <circle cx="100" cy="100" r="92" fill="none" stroke="#7a5330" stroke-width="0.6" opacity="0.55" />
    <circle cx="100" cy="100" r="74" fill="none" stroke="#7a5330" stroke-width="0.4" opacity="0.4" />

    <text x="100" y="50" text-anchor="middle" font-family="GFS Didot, Georgia, serif" font-size="9" letter-spacing="3" fill="#5a3a1e">BRYAN YAO</text>

    <g transform="translate(100 108)" font-family="GFS Didot, Georgia, serif" fill="#3a2a18" text-anchor="middle">
      <text y="-6" font-size="20" letter-spacing="1">BY</text>
      <text y="14" font-size="5" letter-spacing="2.5">BAY AREA</text>
    </g>

    <text x="100" y="162" text-anchor="middle" font-family="GFS Didot, Georgia, serif" font-size="7" letter-spacing="4" fill="#5a3a1e">· MMXXVI ·</text>
  </svg>
  <figcaption class="sr-only">Medallion: Bryan Yao, Bay Area, MMXXVI.</figcaption>
</figure>

<style>
  .medallion {
    width: 160px;
    height: 160px;
    margin: 0;
    border-radius: 50%;
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.45)) drop-shadow(0 1px 0 rgba(255, 255, 255, 0.05));
    pointer-events: none; /* decorative */
  }
  .medallion svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
