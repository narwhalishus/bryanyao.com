---
// Handwritten "Working on" note on cream paper. Opens the now/working drawer.
---

<button
  class="note"
  data-obj="working-on"
  data-drawer="working-on"
  aria-label="What Bryan is working on right now"
>
  <span class="paper" aria-hidden="true">
    <span class="label smallcaps">Working on</span>
    <span class="body display">
      <span>This site.</span>
      <span>SBGA227 servicing.</span>
      <span>Two essays.</span>
    </span>
    <span class="date smallcaps">Apr 2026</span>
  </span>
</button>

<style>
  .note {
    width: 170px;
    height: 138px;
    filter: drop-shadow(0 8px 14px rgba(0, 0, 0, 0.45));
    transition: transform var(--dur-short) var(--ease-out-soft);
  }
  .note:hover,
  .note:focus-visible {
    transform: translateY(-1px) rotate(0.6deg);
  }

  .paper {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    padding: 14px 16px;
    background:
      repeating-linear-gradient(
        to bottom,
        #fff9ea 0,
        #fff9ea 22px,
        rgba(122, 83, 48, 0.18) 23px
      );
    border: 1px solid rgba(122, 83, 48, 0.25);
    border-radius: 2px;
    color: #1a0f05;
    text-align: left;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
    transform: rotate(-1.5deg);
    transform-origin: top left;
  }

  .label {
    color: #7a5330;
    font-size: 0.58rem;
    letter-spacing: 0.24em;
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 4px;
    font-family: var(--font-hand);
    font-size: 1.2rem;
    line-height: 1.45;
    color: #2a1f10;
  }

  .date {
    position: absolute;
    right: 12px;
    bottom: 8px;
    color: #7a5330;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
  }
</style>
