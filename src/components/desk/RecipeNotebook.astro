---
// Leather recipe notebook. Links to /recipes.
---

<a
  class='notebook'
  href='/recipes'
  data-obj='recipe-notebook'
  aria-label='Recipes'
>
  <span class='cover' aria-hidden='true'>
    <span class='band'></span>
    <span class='title display'>Recipes</span>
    <span class='sub smallcaps'>a running ledger</span>
    <span class='corner'></span>
  </span>
</a>

<style>
  .notebook {
    display: inline-block;
    width: 128px;
    height: 170px;
    filter: drop-shadow(0 12px 18px rgba(0, 0, 0, 0.5));
    transition: transform var(--dur-short) var(--ease-out-soft);
  }
  .notebook:hover,
  .notebook:focus-visible {
    transform: translateY(-2px) rotate(-0.6deg);
  }

  .cover {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 2px 6px 6px 2px;
    background:
      radial-gradient(ellipse at 70% 30%, #9a7349 0%, #7a5330 45%, #4d2d14 100%);
    box-shadow:
      inset 6px 0 0 rgba(0, 0, 0, 0.35),
      inset 0 0 0 1px rgba(0, 0, 0, 0.4),
      inset 0 2px 0 rgba(255, 220, 180, 0.12);
  }

  .band {
    position: absolute;
    left: 12px;
    right: 12px;
    top: 44px;
    bottom: 44px;
    border-top: 1px solid rgba(199, 177, 128, 0.6);
    border-bottom: 1px solid rgba(199, 177, 128, 0.6);
  }

  .title {
    position: absolute;
    top: 58px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: var(--step-2);
    font-style: italic;
    color: var(--champagne);
    letter-spacing: 0.02em;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.5);
  }
  .sub {
    position: absolute;
    top: 96px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 0.55rem;
    color: rgba(236, 225, 200, 0.6);
    letter-spacing: 0.24em;
  }
  .corner {
    position: absolute;
    right: 6px;
    top: 6px;
    width: 16px;
    height: 16px;
    background:
      linear-gradient(135deg, transparent 50%, rgba(0, 0, 0, 0.5) 50%);
    border-radius: 0 4px 0 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .notebook {
      transition: none;
    }
    .notebook:hover,
    .notebook:focus-visible {
      transform: none;
    }
  }
</style>
