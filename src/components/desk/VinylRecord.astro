---
// Laufey "Bewitched" vinyl. Links to /listening.
---

<a
  class='vinyl'
  href='/listening'
  data-obj='vinyl'
  aria-label='What Bryan is listening to'
>
  <svg viewBox='0 0 180 180' aria-hidden='true'>
    <defs>
      <radialGradient id='vinyl-grooves' cx='50%' cy='50%' r='50%'>
        <stop offset='0%' stop-color='#1a1a1c' />
        <stop offset='100%' stop-color='#060607' />
      </radialGradient>
    </defs>
    <circle cx='90' cy='90' r='86' fill='url(#vinyl-grooves)' />

    <!-- grooves -->
    <g fill='none' stroke='#2a2a2d' stroke-width='0.35' opacity='0.85'>
      <circle cx='90' cy='90' r='80' />
      <circle cx='90' cy='90' r='74' />
      <circle cx='90' cy='90' r='68' />
      <circle cx='90' cy='90' r='62' />
      <circle cx='90' cy='90' r='56' />
      <circle cx='90' cy='90' r='50' />
    </g>

    <!-- label -->
    <circle cx='90' cy='90' r='38' fill='#c13a2a' />
    <circle cx='90' cy='90' r='38' fill='none' stroke='#6a0f0f' stroke-width='0.5' />
    <text x='90' y='82' text-anchor='middle' font-family='GFS Didot, Georgia, serif' font-size='10' font-style='italic' fill='#fff9ea'>Laufey</text>
    <text x='90' y='96' text-anchor='middle' font-family='Inter, sans-serif' font-size='6' letter-spacing='1.5' fill='#fff9ea' opacity='0.9'>BEWITCHED</text>
    <text x='90' y='108' text-anchor='middle' font-family='Inter, sans-serif' font-size='4' letter-spacing='1.2' fill='#fff9ea' opacity='0.65'>A-SIDE · 33⅓</text>

    <!-- spindle hole -->
    <circle cx='90' cy='90' r='2.5' fill='#15241c' />

    <!-- subtle light reflection -->
    <ellipse cx='56' cy='54' rx='30' ry='6' fill='#fff9ea' opacity='0.06' />
  </svg>
</a>

<style>
  .vinyl {
    display: inline-block;
    width: 170px;
    height: 170px;
    border-radius: 50%;
    filter: drop-shadow(0 14px 22px rgba(0, 0, 0, 0.65));
    transition: transform var(--dur-med) var(--ease-out-soft);
  }
  .vinyl:hover,
  .vinyl:focus-visible {
    transform: rotate(8deg);
  }
  .vinyl svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .vinyl {
      transition: none;
    }
    .vinyl:hover,
    .vinyl:focus-visible {
      transform: none;
    }
  }
</style>
