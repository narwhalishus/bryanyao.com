---
// Thin, quiet top bar. Persists on every page.
// 2-cluster layout with the wordmark centered and a glyph column on the right.
---

<header class='topbar' aria-label='Site header'>
  <nav class='nav nav-left' aria-label='Primary'>
    <a href='/about'>About</a>
    <a href='/journal'>Journal</a>
    <a href='/projects'>Builds</a>
    <a href='/photography'>Photography</a>
  </nav>

  <a href='/' class='wordmark display' aria-label='Bryan Yao — home'
    >Bryan Yao</a
  >

  <nav class='nav nav-right' aria-label='Secondary'>
    <a href='/listening'>Listening</a>
    <a href='/recipes'>Recipes</a>
  </nav>

  <div class='glyphs'>
    <a
      class='glyph'
      href='https://github.com/narwhalishus'
      target='_blank'
      rel='noopener'
      aria-label='GitHub (opens in new tab)'
    >
      <svg viewBox='0 0 16 16' width='16' height='16' aria-hidden='true'>
        <path
          fill='currentColor'
          d='M8 .2a8 8 0 0 0-2.53 15.6c.4.07.55-.17.55-.38v-1.33c-2.23.48-2.7-1.07-2.7-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.24.83 1.24.83.72 1.23 1.88.88 2.34.67.07-.52.28-.88.5-1.08-1.78-.2-3.65-.89-3.65-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.13 0 0 .67-.21 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.03 2.2-.82 2.2-.82.44 1.11.16 1.93.08 2.13.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.66 3.94.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 .2Z'
        ></path>
      </svg>
    </a>

    <a class='glyph' href='mailto:hello@bryanyao.com' aria-label='Email Bryan'>
      <svg viewBox='0 0 16 16' width='16' height='16' aria-hidden='true'>
        <path
          fill='currentColor'
          d='M8 8.9 1.6 4.8A1 1 0 0 1 2.5 3h11a1 1 0 0 1 .9 1.8L8 8.9ZM14.5 6.1V12a1 1 0 0 1-1 1h-11a1 1 0 0 1-1-1V6.1l6.1 3.9a1 1 0 0 0 .8 0l6.1-3.9Z'
        ></path>
      </svg>
    </a>
  </div>
</header>

<style>
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 48px;
    display: grid;
    grid-template-columns: 1fr auto 1fr auto;
    align-items: center;
    gap: 1.25rem;
    padding: 0 clamp(1rem, 2.5vw, 2rem);
    z-index: var(--z-topbar);
    color: var(--ivory);
    background: linear-gradient(
      to bottom,
      rgba(14, 26, 20, 0.82),
      rgba(14, 26, 20, 0.55) 70%,
      rgba(14, 26, 20, 0)
    );
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .topbar::after {
    content: '';
    position: absolute;
    left: clamp(1rem, 2.5vw, 2rem);
    right: clamp(1rem, 2.5vw, 2rem);
    bottom: 0;
    border-bottom: var(--hairline);
  }

  .wordmark {
    font-size: var(--step-1);
    letter-spacing: 0.03em;
    color: var(--ivory);
    justify-self: center;
  }

  .nav {
    display: flex;
    gap: clamp(0.8rem, 2vw, 1.75rem);
    font-size: var(--step--1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ivory-lo);
  }

  .nav-left {
    justify-self: end;
  }
  .nav-right {
    justify-self: start;
  }

  .nav a {
    position: relative;
    padding: 0.25rem 0;
    transition: color var(--dur-short) var(--ease-out-soft);
  }
  .nav a:hover,
  .nav a:focus-visible {
    color: var(--ivory);
  }

  .glyphs {
    display: flex;
    gap: 0.9rem;
    justify-self: end;
    color: var(--platinum);
  }

  .glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    transition: color var(--dur-short) var(--ease-out-soft);
  }

  .glyph:hover,
  .glyph:focus-visible {
    color: var(--platinum-hi);
  }

  @media (max-width: 640px) {
    .topbar {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      height: auto;
      padding-block: 0.5rem;
      gap: 0.5rem 1rem;
    }
    .wordmark {
      grid-row: 1;
      grid-column: 1;
      justify-self: start;
    }
    .glyphs {
      grid-row: 1;
      grid-column: 2;
    }
    .nav {
      grid-row: 2;
      grid-column: 1 / -1;
      justify-self: stretch;
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 0.6rem 0.9rem;
    }
  }
</style>
